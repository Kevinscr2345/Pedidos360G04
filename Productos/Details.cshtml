@model Pedidos360Grupo4.Models.Producto

@{
    ViewData["Title"] = "Detalles del producto";
}

<h1>Detalles del producto</h1>

<div class="card">
    <div class="card-header bg-info text-white">
        Información del producto
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 text-center">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" alt="@Model.Nombre" class="img-fluid rounded shadow-sm" style="max-height: 300px;" />
                }
                else
                {
                    <p class="text-muted my-5">Sin imagen disponible</p>
                }
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-3">Nombre</dt>
                    <dd class="col-sm-9">@Model.Nombre</dd>

                    <dt class="col-sm-3">Categoría</dt>
                    <dd class="col-sm-9">@Model.Categoria.Nombre</dd>

                    <dt class="col-sm-3">Precio</dt>
                    <dd class="col-sm-9">@Model.Precio</dd>

                    <dt class="col-sm-3">Impuesto (%)</dt>
                    <dd class="col-sm-9">@Model.ImpuestoPorc</dd>

                    <dt class="col-sm-3">Stock</dt>
                    <dd class="col-sm-9">@Model.Stock</dd>

                    <dt class="col-sm-3">Estado</dt>
                    <dd class="col-sm-9">@(Model.Activo ? "Activo" : "Inactivo")</dd>
                </dl>

                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </div>
    </div>
</div>