@model Pedidos360Grupo4.ViewModels.PedidoCrearVM
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Nuevo pedido";
}

<h1>Registrar pedido</h1>
<hr />

<form asp-action="Create" method="post" id="formPedido">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row mb-4">
        <div class="col-md-6">
            <label asp-for="ClienteId" class="form-label"></label>
            <select asp-for="ClienteId" asp-items="Model.Clientes" class="form-select">
                <option value="">-- Seleccione un cliente --</option>
            </select>
            <span asp-validation-for="ClienteId" class="text-danger"></span>
        </div>
    </div>

    <div class="table-card mb-4">
        <div class="table-header">
            <span>Agregar productos</span>
        </div>
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Producto</label>
                    <select id="productoSelect" class="form-select">
                        <option value="">-- Seleccione un producto --</option>
                        @foreach (var producto in (IEnumerable<SelectListItem>)ViewBag.Productos)
                        {
                            <option value="@producto.Value">@producto.Text</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Cantidad</label>
                    <input type="number" id="cantidadProducto" class="form-control" min="1" value="1" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Descuento %</label>
                    <input type="number" id="descuentoProducto" class="form-control" min="0" max="100" value="0" />
                </div>

                <div class="col-md-2">
                    <button type="button" id="btnAgregarProducto" class="btn btn-success w-100">Agregar producto</button>
                </div>
            </div>
        </div>
    </div>

    <div class="table-card mb-4">
        <div class="table-header">
            <img src="~/images/logo.png" height="35" />
            <span>Detalle del pedido</span>
        </div>

    <table class="table table-hover" id="tablaLineas">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Descuento %</th>
                <th>Precio unitario</th>
                <th>Impuesto %</th>
                <th>Total línea</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
    </div>

    <div id="contenedorInputsOcultos"></div>

    <div class="row mt-3">
        <div class="col-md-4 ms-auto">
            <div class="table-card">
                <div class="table-header">
                    <span>Totales</span>
                </div>
                <div class="card-body">
                    <p><strong>Subtotal:</strong> ₡ <span id="subtotalPedido">0.00</span></p>
                    <p><strong>Impuestos:</strong> ₡ <span id="impuestosPedido">0.00</span></p>
                    <p><strong>Total:</strong> ₡ <span id="totalPedido">0.00</span></p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success">Guardar pedido</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let lineasPedido = [];
        let productosCache = Array.from(document.querySelectorAll("#productoSelect option"))
            .filter(op => op.value !== "")
            .map(op => ({
                id: parseInt(op.value),
                nombre: op.text
            }));

        async function recalcularTotales() {
            const solicitud = {
                lineas: lineasPedido.map(x => ({
                    productoId: x.productoId,
                    cantidad: x.cantidad,
                    descuento: x.descuento
                }))
            };

            const respuesta = await fetch('/api/pedidos/calcular', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(solicitud)
            });

            const datos = await respuesta.json();

            document.getElementById("subtotalPedido").textContent = (datos.subtotal ?? 0).toFixed(2);
            document.getElementById("impuestosPedido").textContent = (datos.impuestos ?? 0).toFixed(2);
            document.getElementById("totalPedido").textContent = (datos.total ?? 0).toFixed(2);

            const tbody = document.querySelector("#tablaLineas tbody");
            tbody.innerHTML = "";

            lineasPedido.forEach((linea, index) => {
                const detalle = datos.lineas.find(x => x.productoId === linea.productoId);
                const fila = document.createElement("tr");

                fila.innerHTML = `
                    <td>${linea.productoNombre}</td>
                    <td>${linea.cantidad}</td>
                    <td>${linea.descuento}%</td>
                    <td>${detalle ? detalle.precioUnitario.toFixed(2) : "0.00"}</td>
                    <td>${detalle ? (detalle.impuestoPorcentaje * 100).toFixed(0) + "%" : "0%"}</td>
                    <td>${detalle ? detalle.totalLinea.toFixed(2) : "0.00"}</td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm" onclick="eliminarLinea(${index})">Quitar</button>
                    </td>
                `;

                tbody.appendChild(fila);
            });

            renderizarInputsOcultos();
        }

        function renderizarInputsOcultos() {
            const contenedor = document.getElementById("contenedorInputsOcultos");
            contenedor.innerHTML = "";

            lineasPedido.forEach((linea, index) => {
                contenedor.innerHTML += `
                    <input type="hidden" name="Lineas[${index}].ProductoId" value="${linea.productoId}" />
                    <input type="hidden" name="Lineas[${index}].ProductoNombre" value="${linea.productoNombre}" />
                    <input type="hidden" name="Lineas[${index}].Cantidad" value="${linea.cantidad}" />
                    <input type="hidden" name="Lineas[${index}].Descuento" value="${linea.descuento}" />
                `;
            });
        }

        function eliminarLinea(index) {
            lineasPedido.splice(index, 1);
            recalcularTotales();
        }

        document.getElementById("btnAgregarProducto").addEventListener("click", function () {
            const productoId = parseInt(document.getElementById("productoSelect").value);
            const cantidad = parseInt(document.getElementById("cantidadProducto").value);
            const descuento = parseFloat(document.getElementById("descuentoProducto").value);

            if (!productoId || cantidad <= 0 || descuento < 0 || descuento > 100) {
                alert("Debes seleccionar un producto y escribir valores válidos.");
                return;
            }

            const selectProducto = document.getElementById("productoSelect");
            const textoProducto = selectProducto.options[selectProducto.selectedIndex]?.text || "";

            const producto = productosCache.find(p => p.id === productoId);
            if (!producto) {
                alert("No se encontró el producto seleccionado.");
                return;
            }

            const existente = lineasPedido.find(x => x.productoId === productoId);
            if (existente) {
                existente.cantidad += cantidad;
                existente.descuento = descuento;
            } else {
                lineasPedido.push({
                    productoId: producto.id,
                    productoNombre: textoProducto,
                    cantidad: cantidad,
                    descuento: descuento
                });
            }

            document.getElementById("cantidadProducto").value = 1;
            document.getElementById("descuentoProducto").value = 0;
            document.getElementById("productoSelect").value = "";

            recalcularTotales();
        });
    </script>
}