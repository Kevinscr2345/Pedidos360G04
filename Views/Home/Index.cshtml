@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">

    <!-- Título principal -->
    <div class="text-center mb-5">
        <h1 class="fw-bold" style="color:#1E88E5;">Bienvenido a Pedidos360</h1>
        <p class="lead text-muted">Sistema web para la gestión de clientes, productos y pedidos</p>
    </div>

    <!-- Card principal -->
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0" style="border-radius:15px;">
                <div class="card-body text-center p-5">

                    <p style="font-size:18px;">
                        Administra tus <strong>clientes</strong>, <strong>productos</strong> y
                        <strong>pedidos</strong> de forma rápida y eficiente.
                    </p>

                </div>
            </div>
        </div>
    </div>

    <!-- MENSAJE SI ESTÁ LOGUEADO -->
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="row mt-4 justify-content-center">
            <div class="col-md-8">
                <div id="mensajeSesion" class="alert text-center shadow-sm"
                     style="background-color:#1E88E5; color:white; border-radius:10px;">
                    Has iniciado sesión correctamente. Usa el menú superior para navegar entre los módulos del sistema.
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- LOGIN -->
        <div class="row mt-5 justify-content-center">
            <div class="col-md-5">
                <div class="card shadow border-0" style="border-radius:15px;">
                    <div class="card-body text-center p-4">

                        <h4 class="mb-3" style="color:#1E88E5;">Acceso al sistema</h4>

                        <p class="text-muted">
                            Debes iniciar sesión para acceder a las opciones protegidas.
                        </p>

                        <a asp-controller="Acceso" asp-action="IniciarSesion"
                               class="btn w-100"
                               style="background-color:#1E88E5; color:white; border-radius:8px;">
                            Iniciar sesión
                        </a>

                    </div>
                </div>
            </div>
        </div>
    }

</div>

<!-- SCRIPT PARA OCULTAR MENSAJE -->
<script>
    setTimeout(function () {
        var mensaje = document.getElementById("mensajeSesion");
        if (mensaje) {
            mensaje.style.transition = "opacity 0.5s";
            mensaje.style.opacity = "0";
            setTimeout(() => mensaje.remove(), 500);
        }
    }, 2500); // 2 segundos
</script>