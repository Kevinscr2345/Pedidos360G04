@{
    ViewData["Title"] = "Acerca del sistema";
}

<div class="about-container">

    <h1 class="about-title">Acerca del sistema</h1>

    <div class="about-card">

        <p>
            <strong>Pedidos360</strong> es una aplicación web desarrollada en
            <span class="tech">ASP.NET Core MVC</span> para la gestión de clientes,
            productos y pedidos.
        </p>

        <p>
            Utiliza tecnologías como <span class="tech">Entity Framework Core</span>,
            <span class="tech">SQL Server</span> e
            <span class="tech">Identity</span> para la autenticación.
        </p>

        <p>
            Este sistema forma parte de un proyecto académico y demuestra el uso de
            <strong>
                roles, control de acceso, manejo de errores, validaciones,
                API, AJAX y administración de datos.
            </strong>
        </p>

    </div>

</div>