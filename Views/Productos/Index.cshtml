@model IEnumerable<Pedidos360Grupo4.Models.Producto>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Productos";
}

<h1 class="page-title">Productos</h1>

<div class="search-card">
    <form asp-action="Index" method="get" class="row g-2 align-items-center">

        <div class="col-md-4">
            <input type="text" name="searchString" value="@ViewBag.CurrentFilter"
                   class="form-control" placeholder="Buscar producto..." />
        </div>

        <div class="col-md-4">
            <select name="categoriaId" class="form-select" asp-items="@(ViewData["Categorias"] as SelectList)">
            <option value="">-- Todas las categorías --</option>
            </select>
        </div>

        <div class="col-md-4 text-md-end">
            <button type="submit" class="btn btn-success me-2">Filtrar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">Nuevo producto</a>
    </div>
}

<div class="table-card">

    <div class="table-header">
        <img src="~/images/logo.png" height="35" />
        <span>Lista de productos</span>
    </div>

    <table class="table table-hover align-middle">
        <thead >
            <tr>
                <th>Imagen</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Precio</th>
                <th>Impuesto (%)</th>
                <th>Stock</th>
                <th>Estado</th>
                <th style="min-width:220px;">Acciones</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td style="width:100px;text-align:center;">
                        @if (!string.IsNullOrEmpty(item.ImagenUrl))
                        {
                            <img src="@item.ImagenUrl" class="img-thumbnail"
                                 style="height:60px;width:60px;object-fit:cover;" />
                        }
                        else
                        {
                            <span class="text-muted small">Sin imagen</span>
                        }
                    </td>

                    <td>@item.Nombre</td>
                    <td>@item.Categoria.Nombre</td>
                    <td> ₡ @item.Precio.ToString("N2")</td>
                    <td>@item.ImpuestoPorc.ToString("P0")</td>
                    <td>@item.Stock</td>
                    <td>
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>

                    <td>

                        <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm me-1">
                            Detalles
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm me-1">Editar</a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                                class="btn btn-danger btn-sm">Eliminar</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav class="mt-4">
    <ul class="pagination justify-content-center">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.PageIndex ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index",new{pageNumber = i,searchString = ViewBag.CurrentFilter,categoriaId = ViewBag.CurrentCategory})">@i</a>
            </li>
        }
    </ul>
</nav>