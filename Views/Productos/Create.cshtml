@model Pedidos360Grupo4.Models.Producto

@{
    ViewData["Title"] = "Crear producto";
}

<h1>Crear producto</h1>
<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Nombre -->
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label">Nombre del producto</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- Categoría -->
            <div class="form-group mb-3">
                <label asp-for="CategoriaId" class="control-label">Categoría</label>
                <select asp-for="CategoriaId"
                        class="form-control"
                        asp-items="ViewBag.CategoriaId">

                    <option value=""></option>

                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>

            <!-- Precio -->
            <div class="form-group mb-3">
                <label asp-for="Precio" class="control-label">Precio</label>
                <input asp-for="Precio" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>

            <!-- Impuesto -->
            <div class="form-group mb-3">
                <label asp-for="ImpuestoPorc" class="control-label">Impuesto (%)</label>
                <input asp-for="ImpuestoPorc" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="ImpuestoPorc" class="text-danger"></span>
            </div>

            <!-- Stock -->
            <div class="form-group mb-3">
                <label asp-for="Stock" class="control-label">Stock disponible</label>
                <input asp-for="Stock" class="form-control" type="number" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <!-- Imagen -->
            <div class="form-group mb-3">

                <label class="control-label">Imagen del producto</label>

                <input type="file"
                       name="imagenFile"
                       class="form-control"
                       accept="image/*" />

            </div>

            <!-- Activo -->
            <div class="form-group form-check mb-3">
                <input class="form-check-input" asp-for="Activo" />
                <label class="form-check-label">
                    Producto activo
                </label>
            </div>

            <!-- Botones -->
            <div class="form-group">

                <button type="submit" class="btn btn-primary">
                    Crear producto
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}