@model Pedidos360Grupo4.Models.Producto

@{
    ViewData["Title"] = "Detalles del producto";
}

<div class="container mt-4 producto-anim">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color:#1E88E5;">
            <i class="bi bi-box-seam"></i> Detalle del producto
        </h2>
    </div>

    <div class="card shadow border-0">

        <div class="card-body">
            <div class="row">

                <!-- IMAGEN -->
                <div class="col-md-4 text-center">

                    @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                    {
                        <img src="@Model.ImagenUrl"
                             alt="@Model.Nombre"
                             class="img-fluid rounded shadow-sm mb-3"
                             style="max-height: 280px;" />
                    }
                    else
                    {
                        <div class="border rounded p-5 text-muted">
                            <i class="bi bi-image fs-1"></i>
                            <p>Sin imagen</p>
                        </div>
                    }

                    <!-- ESTADO -->
                    <span class="badge fs-6 px-3 py-2 
                        @(Model.Activo ? "bg-success" : "bg-secondary")">
                        @(Model.Activo ? "Activo" : "Inactivo")
                    </span>

                </div>

                <!-- INFORMACIÓN -->
                <div class="col-md-8">

                    <h3 class="fw-bold">@Model.Nombre</h3>
                    <p class="text-muted mb-4">@Model.Categoria.Nombre</p>

                    <div class="row mb-3">

                        <div class="col-md-6">
                            <p><strong><i class="bi bi-cash"></i> Precio:</strong></p>
                            <h4 class="text-primary fw-bold">
                                ₡ @Model.Precio.ToString("N2")
                            </h4>
                        </div>

                        <div class="col-md-6">
                            <p><strong><i class="bi bi-percent"></i> Impuesto:</strong></p>
                            <p>@Model.ImpuestoPorc.ToString("N2") %</p>
                        </div>

                    </div>

                    <div class="mb-3">
                        <p><strong><i class="bi bi-box"></i> Stock disponible:</strong></p>

                        <span class="badge fs-6 px-3 py-2 
                            @(Model.Stock > 10 ? "bg-success" :
                              Model.Stock > 0 ? "bg-warning text-dark" :
                              "bg-danger")">

                            @Model.Stock unidades
                        </span>
                    </div>

                    <!-- BOTONES -->
                    <div class="mt-4">

                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning me-2">
                            <i class="bi bi-pencil"></i> Editar
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>

                    </div>

                </div>

            </div>
        </div>

    </div>

</div>

<!-- ANIMACIÓN -->
<style>
    .producto-anim {
        animation: fadeUp 0.4s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .btn:hover {
        opacity: 0.9;
        transition: 0.3s;
    }
</style>