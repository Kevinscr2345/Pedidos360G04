@model Pedidos360Grupo4.Models.Pedido

@{
    ViewData["Title"] = "Detalle del pedido";
}

<h1 class="page-title">Detalle del pedido #@Model.Id</h1>
<div class="table-card mb-4">

    <div class="table-header">
        <img src="~/images/logo.png" height="35" />
        <span>Información del pedido</span>
    </div>

    <div class="card-body">

    <div class="row text-center">

        <div class="col-md-4">
            <small class="text-muted">Cliente</small>
            <p class="fw-semibold mb-0">@Model.Cliente.Nombre</p>
        </div>

        <div class="col-md-4">
            <small class="text-muted">Fecha</small>
            <p class="mb-0">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

            <div class="col-md-4">
                <small class="text-muted">Estado</small>

                @if (User.IsInRole("Admin"))
                {
                    <form asp-action="CambiarEstado" method="post" class="mt-1 d-flex gap-2">

                        <input type="hidden" name="id" value="@Model.Id" />

                        <select name="nuevoEstado" class="form-select estado w-auto" onchange="this.form.submit()">

                            <option value="@EstadosPedido.Registrado"
                            selected="@(Model.Estado == EstadosPedido.Registrado)">Registrado</option>

                            <option value="@EstadosPedido.EnProceso"
                            selected="@(Model.Estado == EstadosPedido.EnProceso)">En proceso</option>

                            <option value="@EstadosPedido.Completado"
                            selected="@(Model.Estado == EstadosPedido.Completado)">Completado</option>

                            <option value="@EstadosPedido.Cancelado"selected="@(Model.Estado == EstadosPedido.Cancelado)">Cancelado</option>

                        </select>

                        <button type="submit" class="btn btn-primary btn-sm">Guardar</button>

                    </form>
                }
                else
                {
                 <p class="mb-0">@Model.Estado</p>
                }
            </div>
    </div>
</div>
</div>

<div class="table-card mb-4">
    <div class="table-header">
        <span>Productos del pedido</span>
    </div>
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio unitario</th>
                <th>Descuento (%)</th>
                <th>Impuesto (%)</th>
                <th>Total línea</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Detalles)
            {
                <tr>
                    <td>@item.Producto.Nombre</td>
                    <td>@item.Cantidad</td>
                    <td>₡ @item.PrecioUnit.ToString("N2")</td>
                    <td>@item.Descuento.ToString("N0")%</td>
                    <td>@item.ImpuestoPorc.ToString("P0")</td>
                    <td><strong>₡ @item.TotalLinea.ToString("N2")</strong></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="row justify-content-end">
    <div class="col-md-4">
        <div class="table-card">
            <div class="table-header">
                <span>Totales</span>
            </div>
            <div class="card-body">
                <p><strong>Subtotal:</strong> ₡ @Model.Subtotal.ToString("N2")</p>
                <p><strong>Impuestos:</strong> ₡ @Model.Impuestos.ToString("N2")</p>
                <hr /><p class="fs-5"><strong>Total:</strong> ₡ @Model.Total.ToString("N2")</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>